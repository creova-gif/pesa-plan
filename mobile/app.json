{
  "expo": {
    "name": "Maokoto",
    "slug": "maokoto",
    "owner": "jaymafie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "maokoto",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3D2E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.maokoto",
      "buildNumber": "1",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSExceptionDomains": {
            "pesa-plan.replit.app": {
              "NSExceptionAllowsInsecureHTTPLoads": false,
              "NSIncludesSubdomains": true,
              "NSExceptionMinimumTLSVersion": "TLSv1.2"
            }
          }
        },
        "NSCameraUsageDescription": "Maokoto uses the camera to scan receipts and QR codes.",
        "NSPhotoLibraryUsageDescription": "Maokoto accesses your photo library to attach receipts to transactions."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4E886F"
      },
      "package": "app.maokoto",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1A3D2E",
          "image": "./assets/splash.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "924ffc4a-bbbf-45f4-b2a9-4b41b00342dc"
      }
    }
  }
}
